@{
    ViewData["Title"] = "Đăng nhập";
}

<h2 class="mb-4">Đăng nhập nhân viên</h2>

@if (ViewBag.Loi != null)
{
    <div class="alert alert-danger">
        @ViewBag.Loi
    </div>
}

<form method="post">

    <div class="mb-3">
        <label>Email</label>
        <input type="email"
               name="email"
               class="form-control"
               value="@ViewBag.Email" />
    </div>

    <div class="mb-3">
        <label>Mật khẩu</label>
        <input type="password" name="matkhau" class="form-control" />
    </div>

    <div class="form-check mb-3">
        <input class="form-check-input"
               type="checkbox"
               id="remember"
               name="remember"
               value="true" />

        <label class="form-check-label">
            for="remember">
            Ghi nhớ Email
        </label>
    </div>

    <button type="submit" class="btn btn-primary">
        Đăng nhập
    </button>

</form>