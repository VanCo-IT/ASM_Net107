@model IEnumerable<WebCafePoly.Models.SanPham>

@{
    ViewData["Title"] = "Index";
}
<h2 class="mb-3">Quản lý sản phẩm</h2>
<form method="get" class="mb-3">

    <div class="row">

        <div class="col-md-4">
            <input type="text"
                   name="timkiem"
                   class="form-control"
                   placeholder="Nhập tên sản phẩm..." />
        </div>

        <div class="col-md-2">
            <button class="btn btn-primary">
                Tìm kiếm
            </button>
        </div>

    </div>

</form>

<p>
    <a asp-action="Create">➕ Thêm sản phẩm</a>
</p>
<table class="table table-bordered table-hover align-middle">
    <thead>
        <tr>
            <th>
                Tên sản phẩm
            </th>
            <th>
                Đơn giá
            </th>
            <th>
                Loại sản phẩm
            </th>
            <th>
                Hình ảnh
            </th>
            <th>
                Trạng thái
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.TenSanPham)
            </td>
            <td>
                    @item.DonGia.ToString("N0") đ
            </td>
            <td>
                    @item.MaLoaiNavigation?.TenLoai
            </td>
            <td>
                    <img src="~/images/products/@item.HinhAnh"
                         width="100"
                         height="100"
                         class="img-thumbnail"
                         style="object-fit:cover" />
            </td>
            <td>
                    @(item.TrangThai ? "Đang bán" : "Ngừng bán")
            </td>
            <td>
                    <a asp-action="Edit"
                       asp-route-masanpham="@item.MaSanPham"
                       class="btn btn-warning btn-sm">
                        Sửa
                    </a>

                    <a asp-action="Details"
                       asp-route-masanpham="@item.MaSanPham"
                       class="btn btn-info btn-sm">
                        Chi tiết
                    </a>

                    <a asp-action="Delete"
                       asp-route-masanpham="@item.MaSanPham"
                       class="btn btn-danger btn-sm">
                        Xóa
                    </a>
            </td>
        </tr>
}
    </tbody>
</table>
