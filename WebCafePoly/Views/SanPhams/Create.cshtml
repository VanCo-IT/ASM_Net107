@model WebCafePoly.Models.SanPham

@{
    ViewData["Title"] = "Create";
}

<h2>➕ Thêm sản phẩm</h2>
<hr />
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="MaSanPham" class="control-label"></label>
                <input asp-for="MaSanPham" class="form-control" />
                <span asp-validation-for="MaSanPham" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TenSanPham" class="control-label"></label>
                <input asp-for="TenSanPham" class="form-control" />
                <span asp-validation-for="TenSanPham" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DonGia" class="control-label"></label>
                <input asp-for="DonGia" class="form-control" />
                <span asp-validation-for="DonGia" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="MaLoai" class="control-label"></label>
                @* <input asp-for="MaLoai" class="form-control" /> *@
                <select asp-for="MaLoai"
                        asp-items="ViewBag.MaLoai"
                        class="form-select">
                </select>

                <span asp-validation-for="MaLoai" class="text-danger"></span>
                @* <span asp-validation-for="MaLoai" class="text-danger"></span> *@
            </div>

            <div class="form-group">
                <label asp-for="HinhAnh" class="control-label"></label>
                <input asp-for="HinhAnh" class="form-control" />
                <span asp-validation-for="HinhAnh" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="TrangThai" class="control-label"></label>
                <input asp-for="TrangThai" class="form-check-input" />
                <span asp-validation-for="TrangThai" class="text-danger"></span>
            </div>

            @* <div class="form-group">
                <label asp-for="ChiTietPhieus" class="control-label"></label>
                <input asp-for="ChiTietPhieus" class="form-control" />
                <span asp-validation-for="ChiTietPhieus" class="text-danger"></span>
            </div> *@

            @* <div class="form-group">
                <label asp-for="MaLoaiNavigation" class="control-label"></label>
                <input asp-for="MaLoaiNavigation" class="form-control" />
                <span asp-validation-for="MaLoaiNavigation" class="text-danger"></span>
            </div> *@
            <div class="form-group">
                <input type="submit" value="Thêm sản phẩm" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}