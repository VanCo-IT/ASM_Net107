@model IEnumerable<WebCafePoly.Models.ChiTietPhieu>
<table class="table table-bordered">
    <thead>
        <tr>
            <th>Tên sản phẩm</th>
            <th>Đơn giá</th>
            <th>Số lượng</th>
            <th>Thành tiền</th>
        </tr>
    </thead>
    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MaSanPhamNavigation.TenSanPham</td>
                <td>@item.DonGia.ToString("N0") VNĐ</td>
                <td>@item.SoLuong</td>
                <td>@((item.DonGia * item.SoLuong).ToString("N0")) VNĐ</td>
            </tr>
        }

    </tbody>
</table>
<h4>
    Tổng tiền:
    @Model.Sum(x => x.DonGia * x.SoLuong).ToString("N0") VNĐ
</h4>
